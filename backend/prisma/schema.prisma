generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Skill {
  id             Int              @id @default(autoincrement())
  name           String           @unique
  developerSkills DeveloperSkill[]
  taskSkills     TaskSkill[]
}

model Developer {
  id             Int              @id @default(autoincrement())
  name           String
  skills         DeveloperSkill[]
  tasks          Task[]
}

model DeveloperSkill {
  developerId Int
  skillId     Int
  developer   Developer @relation(fields: [developerId], references: [id])
  skill       Skill     @relation(fields: [skillId], references: [id])

  @@id([developerId, skillId])
}

model Task {
  id                  Int         @id @default(autoincrement())
  title               String
  status              String      @default("To-do")
  assignedDeveloperId Int?
  parentTaskId        Int?
  createdAt           DateTime    @default(now())
  assignedDeveloper   Developer?  @relation(fields: [assignedDeveloperId], references: [id])
  parentTask          Task?       @relation("TaskSubtasks", fields: [parentTaskId], references: [id])
  childTasks          Task[]      @relation("TaskSubtasks")
  skills              TaskSkill[]
}

model TaskSkill {
  taskId  Int
  skillId Int
  task    Task  @relation(fields: [taskId], references: [id])
  skill   Skill @relation(fields: [skillId], references: [id])

  @@id([taskId, skillId])
}
